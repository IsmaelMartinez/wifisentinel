{
  "name": "wifisentinel",
  "version": "1.0.0",
  "description": "Multi-persona WiFi/network security analyser with OTEL instrumentation",
  "type": "module",
  "license": "MIT",
  "author": "Ismael Martinez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IsmaelMartinez/wifisentinel.git"
  },
  "keywords": [
    "wifi",
    "network",
    "security",
    "scanner",
    "reconnaissance",
    "cli"
  ],
  "bin": {
    "wifisentinel": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "scan": "tsx src/cli.ts scan",
    "typecheck": "tsc -p tsconfig.check.json",
    "dashboard": "cd dashboard && npx next dev --hostname 127.0.0.1",
    "test": "find tests -name '*.test.ts' | xargs node --import tsx --test",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "figures": "^6.1.0",
    "listr2": "^10.2.1",
    "log-update": "^7.2.0",
    "oui-data": "^1.1.564",
    "sparkly": "^6.0.1",
    "terminal-link": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  },
  "engines": {
    "node": ">=20"
  }
}
